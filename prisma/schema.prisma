// VivaahAI — local development database (SQLite via Prisma)
// See plan: docs/architecture decision is SQLite for zero-infra real persistence.
// Swapping to Postgres later only requires changing `provider` + `DATABASE_URL`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  phone          String   @unique
  passwordHash   String
  phoneVerified  Boolean  @default(false)
  onboardingStep String   @default("complete")
  gender         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile       Profile?
  preference    Preference?
  subscriptions Subscription[]
  contactMessages ContactMessage[]

  likesGiven    Like[]    @relation("LikesGiven")
  likesReceived Like[]    @relation("LikesReceived")
  matchesA      Match[]   @relation("MatchUserA")
  matchesB      Match[]   @relation("MatchUserB")
  bookmarksMade     Bookmark[] @relation("BookmarkOwner")
  bookmarksReceived Bookmark[] @relation("BookmarkTarget")

  conversationsA Conversation[] @relation("ConversationUserA")
  conversationsB Conversation[] @relation("ConversationUserB")
  messagesSent   Message[]      @relation("MessageSender")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  gender         String?
  dob            String?
  height         String?
  religion       String?
  caste          String?
  motherTongue   String?
  maritalStatus  String?

  qualification  String?
  occupation     String?
  company        String?
  annualIncome   String?

  country        String?
  state          String?
  city           String?

  aboutMe        String?
  interests      String  @default("[]") // JSON-encoded string[]
  photo          String?
  coverPhoto     String?
  photos         String  @default("[]") // JSON-encoded string[] — up to 4 additional gallery photos

  isVerified     Boolean @default(false)
  isOnline       Boolean @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Preference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  ageMin          Int      @default(18)
  ageMax          Int      @default(35)
  religion        String   @default("Any Religion")
  location        String?
  education       String   @default("Any")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Like {
  id           String   @id @default(cuid())
  fromUserId   String
  toUserId     String
  createdAt    DateTime @default(now())

  fromUser User @relation("LikesGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("LikesReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String
  createdAt    DateTime @default(now())

  user       User @relation("BookmarkOwner", fields: [userId], references: [id], onDelete: Cascade)
  targetUser User @relation("BookmarkTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId])
}

model Match {
  id           String   @id @default(cuid())
  userAId      String
  userBId      String
  matchPercent Int
  tag          String   @default("new") // new | compatible | mutual | premium
  createdAt    DateTime @default(now())

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  tier      String   // premium | elite
  status    String   @default("pending") // pending | active | cancelled
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  fullName  String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
