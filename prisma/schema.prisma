generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DATABASE_PROVIDER") // "sqlite" (dev) | "postgresql" (prod)
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  phone          String   @unique
  passwordHash   String
  phoneVerified  Boolean  @default(false)
  onboardingStep String   @default("complete")
  gender         String?
  referralCode   String   @unique @default(cuid())
  referredBy     String?
  e2ePublicKey   String?  // X25519 public key for E2E message encryption (base64)
  fcmToken       String?  // Firebase Cloud Messaging token for push notifications
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile         Profile?
  preference      Preference?
  verification    Verification?
  subscriptions   Subscription[]
  contactMessages ContactMessage[]

  likesGiven     Like[]    @relation("LikesGiven")
  likesReceived  Like[]    @relation("LikesReceived")
  passesGiven    Pass[]    @relation("PassesGiven")
  passesReceived Pass[]    @relation("PassesReceived")

  reportsMade     UserReport[] @relation("ReportsMade")
  reportsReceived UserReport[] @relation("ReportsReceived")
  matchesA       Match[]   @relation("MatchUserA")
  matchesB       Match[]   @relation("MatchUserB")
  bookmarksMade      Bookmark[] @relation("BookmarkOwner")
  bookmarksReceived  Bookmark[] @relation("BookmarkTarget")

  conversationsA Conversation[] @relation("ConversationUserA")
  conversationsB Conversation[] @relation("ConversationUserB")
  messagesSent   Message[]      @relation("MessageSender")

  viewsGiven    ProfileView[] @relation("ViewsGiven")
  viewsReceived ProfileView[] @relation("ViewsReceived")

  // Freemium daily match limit tracking
  freeMatchesUsed Int    @default(0)
  freeMatchesDate String @default("")
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Profile {
  id            String @id @default(cuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  gender        String?
  dob           String?
  height        String?
  religion      String?
  caste         String?
  motherTongue  String?
  maritalStatus String?

  qualification String?
  occupation    String?
  company       String?
  annualIncome  String?

  country       String?
  state         String?
  city          String?

  aboutMe       String?
  interests     String   @default("[]") // JSON-encoded string[]
  photo         String?
  coverPhoto    String?
  photos        String   @default("[]") // JSON-encoded string[] — up to 4 gallery photos

  // Lifestyle fields for matching
  smokingHabit   String? // never | occasionally | regularly
  drinkingHabit  String? // never | occasionally | regularly
  dietPreference String? // vegetarian | non-vegetarian | vegan | eggetarian

  isVerified    Boolean   @default(false)
  isOnline      Boolean   @default(false)
  lastActiveAt  DateTime?
  boostExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Preference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ageMin            Int    @default(18)
  ageMax            Int    @default(35)
  religion          String @default("Any Religion")
  location          String?
  education         String @default("Any")
  castePreference   String?
  maritalStatusPref String?
  smokingPref       String?
  drinkingPref      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  fromUser User @relation("LikesGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("LikesReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model Pass {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  fromUser User @relation("PassesGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("PassesReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model Bookmark {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String
  createdAt    DateTime @default(now())

  user       User @relation("BookmarkOwner", fields: [userId], references: [id], onDelete: Cascade)
  targetUser User @relation("BookmarkTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId])
}

model Match {
  id           String   @id @default(cuid())
  userAId      String
  userBId      String
  matchPercent Int
  tag          String   @default("new") // new | compatible | mutual | premium
  createdAt    DateTime @default(now())

  userA User @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userALastReadAt DateTime?
  userBLastReadAt DateTime?

  userA User @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)

  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  tier               String    // free | gold | platinum | diamond
  status             String    @default("pending") // pending | active | cancelled | failed
  amount             Int       @default(0)         // in paise (₹499 = 49900)
  razorpayOrderId    String?
  razorpayPaymentId  String?
  startedAt          DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  profileId String
  createdAt DateTime @default(now())

  viewer  User @relation("ViewsGiven",    fields: [viewerId],  references: [id], onDelete: Cascade)
  profile User @relation("ViewsReceived", fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([viewerId])
}

model Verification {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneVerified  Boolean  @default(false)

  idType         String?  // aadhaar | pan | passport | driving_license
  idNumber       String?
  idVerified     Boolean  @default(false)
  idVerifiedAt   DateTime?

  livenessStatus String   @default("not_started") // not_started | pending | approved | rejected
  selfieUrl      String?
  livenessAt     DateTime?

  fraudScore     Int      @default(0)
  overallStatus  String   @default("unverified") // unverified | pending | verified | rejected

  verifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  type       String   // like | match | message | view | referral | boost
  title      String
  body       String
  fromUserId String?
  fromName   String?
  fromPhoto  String?
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model ReferralReward {
  id          String   @id @default(cuid())
  referrerId  String
  refereeId   String
  status      String   @default("pending") // pending | rewarded
  rewardDays  Int      @default(30)
  createdAt   DateTime @default(now())
  rewardedAt  DateTime?

  @@unique([referrerId, refereeId])
  @@index([referrerId])
}

model SuccessStory {
  id            String   @id @default(cuid())
  userId        String
  partnerName   String
  story         String
  marriageDate  String?
  city          String?
  photo         String?
  status        String   @default("pending") // pending | approved | rejected
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model UserReport {
  id          String   @id @default(cuid())
  reporterId  String
  reportedId  String
  reason      String   // harassment | fake_profile | spam | inappropriate_photos | scam | other
  description String?
  status      String   @default("pending") // pending | reviewed | actioned | dismissed
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User @relation("ReportsMade",     fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reportedId])
  @@unique([reporterId, reportedId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  // admin or user id
  actorName  String?
  action     String   // signup | login | upgrade | verify | ban | unban | delete | report | approve_story | reject_story
  targetId   String?
  targetName String?
  meta       String?  // JSON string with extra context
  ip         String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([actorId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  fullName  String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
