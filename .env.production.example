# ============================================
# VivaahAI Production Environment (Railway)
# Copy these to Railway → Variables
# ============================================

# Database — Railway PostgreSQL addon se milta hai
DATABASE_URL=postgresql://user:password@host:5432/railway
DATABASE_PROVIDER=postgresql

# API
NEXT_PUBLIC_API_BASE_URL=https://YOUR-APP.railway.app

# Auth
NEXTAUTH_URL=https://YOUR-APP.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Razorpay (live keys use karo production mein)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY=rzp_live_XXXXXXXXXX
RAZORPAY_SECRET=XXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Socket.IO
NEXT_PUBLIC_SOCKET_URL=https://YOUR-APP.railway.app
SOCKET_IO_SECRET=strong-random-secret

# Email (Gmail App Password)
EMAIL_FROM=VivaahAI <noreply@yourdomain.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# AWS S3 (photo upload)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=vivaah-photos
AWS_CLOUDFRONT_URL=https://xxxxxx.cloudfront.net

# Admin
ADMIN_EMAILS=arun@techotd.com

# Feature Flags
FEATURE_AI_MATCHING=false
FEATURE_VIDEO_CALLS=false
FEATURE_FAMILY_ACCOUNTS=false
FEATURE_BACKGROUND_CHECK=false

NODE_ENV=production
