# Database — Supabase PostgreSQL (Project Settings → Database → Connection String)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DATABASE_PROVIDER=postgresql

# API
NEXT_PUBLIC_API_BASE_URL=https://vivaahai.techotd.in

# Auth
NEXTAUTH_URL=https://vivaahai.techotd.in
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Razorpay (live keys use karo production mein)
RAZORPAY_KEY_ID="rzp_test_T7N0JLondNePD4"
RAZORPAY_KEY_SECRET="gXP5U4ectsQQ507qDuMMIz27"
RAZORPAY_WEBHOOK_SECRET="vivaah123webhook"
NEXT_PUBLIC_RAZORPAY_KEY="rzp_test_T7N0JLondNePD4"
RAZORPAY_SECRET="gXP5U4ectsQQ507qDuMMIz27"

# Socket.IO
NEXT_PUBLIC_SOCKET_URL=https://vivaahai.techotd.in
SOCKET_IO_SECRET=strong-random-secret

# Email (Gmail App Password)
EMAIL_FROM=VivaahAI <noreply@vivaahai.techotd.in>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# AWS S3 (photo upload)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=vivaah-photos
AWS_CLOUDFRONT_URL=https://xxxxxx.cloudfront.net

# Admin
ADMIN_EMAILS=arun@techotd.com

# Feature Flags
FEATURE_AI_MATCHING=false
FEATURE_VIDEO_CALLS=false
FEATURE_FAMILY_ACCOUNTS=false
FEATURE_BACKGROUND_CHECK=false

NODE_ENV=production
