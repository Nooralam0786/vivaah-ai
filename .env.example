# ============================================
# VivaahAI Environment Configuration
# ============================================

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_TIMEOUT=30000

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vivaahdb
MONGODB_URL=mongodb://localhost:27017/vivaahdb

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vivaah-photos
AWS_CLOUDFRONT_URL=https://cdn.vivaah.ai

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay (Payments)
NEXT_PUBLIC_RAZORPAY_KEY=
RAZORPAY_SECRET=

# Socket.IO
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000
SOCKET_IO_SECRET=

# ML/AI Services
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=vivaah-embeddings

# Verification Services
FACE_RECOGNITION_API_URL=
LIVENESS_DETECTION_API_URL=

# Email Configuration
EMAIL_FROM=noreply@vivaah.ai
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Monitoring & Logging
SENTRY_DSN=
DATADOG_API_KEY=
LOG_LEVEL=info

# Feature Flags
FEATURE_AI_MATCHING=false
FEATURE_VIDEO_CALLS=false
FEATURE_FAMILY_ACCOUNTS=false
FEATURE_BACKGROUND_CHECK=false

# Node Environment
NODE_ENV=development
